# caliclaw Configuration

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ALLOWED_USERS=123456789,987654321

# Claude Code
CLAUDE_BINARY=claude
CLAUDE_DEFAULT_MODEL=sonnet

# Paths
DATA_DIR=./data
WORKSPACE_DIR=./workspace
AGENTS_DIR=./agents
SKILLS_DIR=./skills
MEMORY_DIR=./memory

# Limits
MAX_CONCURRENT_AGENTS=3
MAX_LOOP_ITERATIONS=20
MAX_LOOP_DURATION_MINUTES=120
USAGE_PAUSE_PERCENT=80
USAGE_EMERGENCY_PERCENT=90
USAGE_STOP_PERCENT=95

# Heartbeat
HEARTBEAT_QUICK_CRON=*/5 * * * *
HEARTBEAT_REVIEW_CRON=*/30 * * * *
HEARTBEAT_MORNING_CRON=0 9 * * *
HEARTBEAT_DREAM_CRON=0 3 * * *

# Whisper
WHISPER_CPP_PATH=/usr/local/bin/whisper-cpp
WHISPER_MODEL_PATH=./models/ggml-base.bin

# Vault
VAULT_KEY_PATH=~/.caliclaw/vault.key

# Dashboard
DASHBOARD_PORT=8080
DASHBOARD_ENABLED=true

# Timezone
TZ=Europe/Moscow

# Logging
LOG_LEVEL=INFO
