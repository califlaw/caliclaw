# Secrets
.env

# Virtual environment
.venv/
venv/
vault/secrets.enc
~/.caliclaw/

# Database
data/*.db
data/*.db-wal
data/*.db-shm

# Runtime state (per-host, generated after init)
data/caliclaw.pid
data/caliclaw.generated.service
data/pairing_code.txt
data/enabled_skills.txt
data/backup_state.json

# Per-user agent files (generated by init; never publish)
agents/global/main/USER.md
agents/global/main/SOUL.md
agents/global/main/IDENTITY.md

# Runtime
logs/*.log
workspace/media/*
workspace/ipc/*
workspace/conversations/*
workspace/projects/*
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/

# Models (large files)
models/

# Vendor builds
vendor/

# Backups
backups/

# Build artifacts
dist/
*.egg-info/

# Cython compiled artifacts (platform-specific, built on install)
bin/_engine.c
bin/*.so
build/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
